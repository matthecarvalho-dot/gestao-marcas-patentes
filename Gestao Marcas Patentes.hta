<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Gestão de Marcas e Patentes</title>
    <HTA:APPLICATION 
        ID="GestaoApp"
        APPLICATIONNAME="GestaoMarcasPatentes"
        BORDER="thick"
        BORDERSTYLE="complex"
        CAPTION="yes"
        INNERBORDER="no"
        MAXIMIZEBUTTON="yes"
        MINIMIZEBUTTON="yes"
        SYSMENU="yes"
        WINDOWSTATE="maximize"
    />
    <style>
        body { margin: 0; padding: 0; overflow: hidden; background: #06080c; }
        iframe { width: 100%; height: 100vh; border: none; }
    </style>
    <script>
        window.onload = function() {
            // Carrega o sistema do GitHub
            document.getElementById('appFrame').src = 'https://matthecarvalho-dot.github.io/gestao-marcas-patentes/';
        }
    </script>
</head>
<body>
    <iframe id="appFrame"></iframe>
</body>
</html>
